+/* static */ bool
+ScreenDimensionManager::IsWindowFunctionEnabledForWebIDL(JSContext* aCx,
+                                                         JSObject* aObj) {
+  nsGlobalWindowInner* win = xpc::WindowOrNull(aObj);
+  if (!win) {
+    return false;
+  }
+
+  uint32_t userContextId = 0;
+  if (BrowsingContext* bc = win->GetBrowsingContext()) {
+    userContextId = bc->OriginAttributesRef().mUserContextId;
+  }
+
+  bool disabled = false;
+  RoverfoxStorageManager::GetBool(WindowDisabledKeyForUserContext(userContextId),
+                                  disabled);
+  return !disabled;
+}
