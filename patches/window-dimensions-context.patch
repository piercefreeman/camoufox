+/* static */ void
+ScreenDimensionManager::WindowKey(uint32_t aUserContextId, const char* aName,
+                                  nsString& aKey) {
+  aKey.AppendPrintf("%s_%u", aName, aUserContextId);
+}
+
+/* static */ void
+ScreenDimensionManager::SetWindowDimensions(uint32_t aUserContextId,
+                                            int32_t aOuterWidth,
+                                            int32_t aOuterHeight,
+                                            int32_t aInnerWidth,
+                                            int32_t aInnerHeight,
+                                            int32_t aScreenX,
+                                            int32_t aScreenY) {
+  struct WindowValue {
+    const char* name;
+    int32_t value;
+  };
+  const WindowValue values[] = {
+      {"windowOuterWidth", aOuterWidth},
+      {"windowOuterHeight", aOuterHeight},
+      {"windowInnerWidth", aInnerWidth},
+      {"windowInnerHeight", aInnerHeight},
+      {"windowScreenX", aScreenX},
+      {"windowScreenY", aScreenY},
+  };
+
+  for (const auto& entry : values) {
+    nsString key;
+    WindowKey(aUserContextId, entry.name, key);
+    RoverfoxStorageManager::PutUint(key, static_cast<uint32_t>(entry.value));
+  }
+}
+
+/* static */ bool
+ScreenDimensionManager::GetWindowValue(uint32_t aUserContextId,
+                                       const char* aName, int32_t* aValue) {
+  nsString key;
+  WindowKey(aUserContextId, aName, key);
+  uint32_t value = 0;
+  if (!RoverfoxStorageManager::GetUint(key, value)) {
+    return false;
+  }
+  *aValue = static_cast<int32_t>(value);
+  return true;
+}
