diff --git a/build/moz.configure/toolchain.configure b/build/moz.configure/toolchain.configure
--- a/build/moz.configure/toolchain.configure
+++ b/build/moz.configure/toolchain.configure
@@ -234,6 +234,12 @@ with only_when(host_is_osx | target_is_osx):
    def mac_sdk_min_version():
        return "26.2"
 
+    def mac_sdk_bootstrap_version():
+        # Keep the bootstrapped SDK metadata in sync with Firefox main:
+        # https://searchfox.org/firefox-main/source/taskcluster/kinds/toolchain/macos-sdk.yml
+        # Do not raise mac_sdk_min_version here; local Xcode 26.2 SDKs remain valid for Firefox 150.
+        return "26.4"
+
     @depends(
         "--with-macos-sdk",
         host,
@@ -241,5 +247,5 @@ with only_when(host_is_osx | target_is_osx):
         bootstrap_path(
-            "MacOSX{}.sdk".format(mac_sdk_min_version()),
+            "MacOSX{}.sdk".format(mac_sdk_bootstrap_version()),
             when=depends("--with-macos-sdk")(lambda x: not x),
             allow_failure=True,
         ),
