+        # https://searchfox.org/firefox-main/source/taskcluster/kinds/toolchain/macos-sdk.yml
+        # Do not raise mac_sdk_min_version here; local Xcode 26.2 SDKs remain valid for Firefox 146.
+        return "26.4"
+
     @depends(
         "--with-macos-sdk",
         host,
@@ -235,7 +241,7 @@ with only_when(host_is_osx | target_is_osx):
-            "MacOSX{}.sdk".format(mac_sdk_min_version()),
+            "MacOSX{}.sdk".format(mac_sdk_bootstrap_version()),
             when=depends("--with-macos-sdk")(lambda x: not x),
             allow_failure=True,
         ),
