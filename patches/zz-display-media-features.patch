+static StyleColorGamut CamoufoxColorGamutFromProfileValue(
+    const std::string& aValue) {
+  if (aValue == "rec2020") {
+    return StyleColorGamut::Rec2020;
+  }
+  if (aValue == "p3") {
+    return StyleColorGamut::P3;
+  }
+  return StyleColorGamut::Srgb;
+}
+
+static StyleDynamicRange CamoufoxDynamicRangeFromProfileValue(
+    const std::string& aValue) {
+  return aValue == "high" ? StyleDynamicRange::High
+                           : StyleDynamicRange::Standard;
+}
