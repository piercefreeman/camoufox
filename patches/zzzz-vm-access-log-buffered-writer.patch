+static void AppendFormat(std::string& out, const char* format, ...) {
+  char stackBuffer[512];
+  va_list args;
+  va_start(args, format);
+  va_list argsCopy;
+  va_copy(argsCopy, args);
+  int needed = vsnprintf(stackBuffer, sizeof(stackBuffer), format, args);
+  va_end(args);
+
+  if (needed < 0) {
+    va_end(argsCopy);
+    return;
+  }
+
+  if (size_t(needed) < sizeof(stackBuffer)) {
+    out.append(stackBuffer, size_t(needed));
+    va_end(argsCopy);
+    return;
+  }
+
+  size_t oldLength = out.length();
+  out.resize(oldLength + size_t(needed) + 1);
+  vsnprintf(&out[oldLength], size_t(needed) + 1, format, argsCopy);
+  out.resize(oldLength + size_t(needed));
+  va_end(argsCopy);
+}
