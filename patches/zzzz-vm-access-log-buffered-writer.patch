+static void WriteDirect(const char* line) {
+  FILE* stream = gLogFile ? gLogFile : stderr;
+  fputs(line, stream);
+  fflush(stream);
+}
+
+static void LogWriterMain() {
+  ThisThread::SetName("Camoufox VM Access Log");
+
+  mozilla::Vector<std::string, 0, SystemAllocPolicy> batch;
+  while (true) {
+    uint64_t dropped = 0;
+    {
+      UniqueLock<Mutex> lock(gLogMutex);
+      gLogWakeup.wait(lock, []() {
+        return gLogWriterStopping || !gLogQueue.empty() || gDroppedLines;
+      });
+
+      if (gLogQueue.empty() && !gDroppedLines && gLogWriterStopping) {
+        break;
+      }
+
+      dropped = gDroppedLines;
+      gDroppedLines = 0;
+      gLogQueue.swap(batch);
+      gQueuedBytes = 0;
+    }
+
+    FILE* stream = gLogFile ? gLogFile : stderr;
+    if (dropped) {
+      fprintf(stream,
+              "[camoufox-vm-access] op=log-dropped count=%" PRIu64
+              " reason=queue-full\n",
+              dropped);
+    }
+    for (const std::string& line : batch) {
+      fputs(line.c_str(), stream);
+    }
+    batch.clear();
+    fflush(stream);
+  }
+
+  FILE* stream = gLogFile ? gLogFile : stderr;
+  fflush(stream);
+}
+
+static void ShutdownLogWriter() {
+  if (gLogWriterStarted) {
+    {
+      UniqueLock<Mutex> lock(gLogMutex);
+      gLogWriterStopping = true;
+      gLogWakeup.notify_one();
+    }
+
+    if (gLogWriterThread && gLogWriterThread->joinable()) {
+      gLogWriterThread->join();
+    }
+    js_delete(gLogWriterThread);
+    gLogWriterThread = nullptr;
+    gLogWriterStarted = false;
+  }
+
+  if (gLogFile) {
+    fclose(gLogFile);
+    gLogFile = nullptr;
+  }
+}
+
+static bool StartLogWriter() {
+  const char* buffered = getenv("CAMOUFOX_VM_ACCESS_BUFFERED");
+  if (!gLogFile || gLogWriterStarted ||
+      (buffered && !EnvFlagEnabled(buffered))) {
+    return false;
+  }
+
+  gLogWriterThread = js_new<Thread>();
+  if (!gLogWriterThread) {
+    return false;
+  }
+
+  if (!gLogWriterThread->init(LogWriterMain)) {
+    js_delete(gLogWriterThread);
+    gLogWriterThread = nullptr;
+    return false;
+  }
+
+  gLogWriterStarted = true;
+  return true;
+}
+
+static void EnqueueLogLine(std::string&& line) {
+  if (!gLogWriterStarted) {
+    WriteDirect(line.c_str());
+    return;
+  }
+
+  UniqueLock<Mutex> lock(gLogMutex);
+  if (gLogWriterStopping) {
+    gDroppedLines++;
+    return;
+  }
+
+  size_t lineBytes = line.size();
+  if (gQueuedBytes + lineBytes > gMaxQueueBytes) {
+    gDroppedLines++;
+    gLogWakeup.notify_one();
+    return;
+  }
+
+  if (!gLogQueue.append(std::move(line))) {
+    gDroppedLines++;
+    gLogWakeup.notify_one();
+    return;
+  }
+
+  gQueuedBytes += lineBytes;
+  gLogWakeup.notify_one();
+}
+
+static void AppendFormat(std::string& out, const char* format, ...) {
+  char stackBuffer[512];
+  va_list args;
+  va_start(args, format);
+  va_list argsCopy;
+  va_copy(argsCopy, args);
+  int needed = vsnprintf(stackBuffer, sizeof(stackBuffer), format, args);
+  va_end(args);
+
+  if (needed < 0) {
+    va_end(argsCopy);
+    return;
+  }
+
+  if (size_t(needed) < sizeof(stackBuffer)) {
+    out.append(stackBuffer, size_t(needed));
+    va_end(argsCopy);
+    return;
+  }
+
+  size_t oldLength = out.length();
+  out.resize(oldLength + size_t(needed) + 1);
+  vsnprintf(&out[oldLength], size_t(needed) + 1, format, argsCopy);
+  out.resize(oldLength + size_t(needed));
+  va_end(argsCopy);
+}
