+static uint32_t InternStringLocked(const char* value) {
+  if (!value) {
+    return kNoStringId;
+  }
+
+  auto found = gInternedStringIds.find(value);
+  if (found != gInternedStringIds.end()) {
+    return found->second;
+  }
+
+  uint32_t id = uint32_t(gInternedStrings.length() + 1);
+  std::string owned(value);
+  if (!gInternedStrings.append(std::move(owned))) {
+    return kNoStringId;
+  }
+
+  gInternedStringIds.emplace(gInternedStrings[id - 1], id);
+  return id;
+}
+
+static uint32_t InternString(const char* value) {
+  UniqueLock<Mutex> lock(gInternMutex);
+  return InternStringLocked(value);
+}
+
+static uint32_t InternStaticString(const char* value) {
+  if (!value) {
+    return kNoStringId;
+  }
+
+  UniqueLock<Mutex> lock(gInternMutex);
+  auto found = gPointerStringIds.find(value);
+  if (found != gPointerStringIds.end()) {
+    return found->second;
+  }
+
+  uint32_t id = InternStringLocked(value);
+  if (id) {
+    gPointerStringIds.emplace(value, id);
+  }
+  return id;
+}
+
+static std::string CopyInternedString(uint32_t id, const char* fallback) {
+  if (!id) {
+    return fallback ? std::string(fallback) : std::string();
+  }
+
+  UniqueLock<Mutex> lock(gInternMutex);
+  size_t index = size_t(id - 1);
+  if (index >= gInternedStrings.length()) {
+    return fallback ? std::string(fallback) : std::string();
+  }
+  return gInternedStrings[index];
+}
