+static uint32_t InternRealm(JSContext* cx, JS::Realm* realm) {
+  if (!gLogRealm || !cx || !realm) {
+    return kNoStringId;
+  }
+
+  {
+    UniqueLock<Mutex> lock(gInternMutex);
+    auto found = gRealmStringIds.find(realm);
+    if (found != gRealmStringIds.end()) {
+      return found->second;
+    }
+  }
+
+  auto nameCallback = cx->runtime()->realmNameCallback;
+  if (!nameCallback) {
+    return kNoStringId;
+  }
+
+  char buffer[512];
+  buffer[0] = '\0';
+  JS::AutoSuppressGCAnalysis nogc;
+  nameCallback(cx, realm, buffer, sizeof(buffer), nogc);
+  buffer[sizeof(buffer) - 1] = '\0';
+  if (!buffer[0]) {
+    return kNoStringId;
+  }
+
+  uint32_t id = InternString(buffer);
+  if (!id) {
+    return kNoStringId;
+  }
+
+  UniqueLock<Mutex> lock(gInternMutex);
+  auto found = gRealmStringIds.find(realm);
+  if (found != gRealmStringIds.end()) {
+    return found->second;
+  }
+  gRealmStringIds.emplace(realm, id);
+  return id;
+}
