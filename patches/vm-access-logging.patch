index 0000000000..f34430a47a
--- /dev/null
+++ b/js/src/vm/CamoufoxVMAccessLog.cpp
@@ -0,0 +1,189 @@
+/* -*- Mode: C++; tab-width: 8; indent-tabs-mode: nil; c-basic-offset: 2 -*-
+ * vim: set ts=8 sts=2 et sw=2 tw=80:
+ * This Source Code Form is subject to the terms of the Mozilla Public
+ * License, v. 2.0. If a copy of the MPL was not distributed with this
+ * file, You can obtain one at http://mozilla.org/MPL/2.0/.
+ */
+
+#include "vm/CamoufoxVMAccessLog.h"
+
+#include <stdio.h>
+#include <stdlib.h>
+#include <stdint.h>
+#include <string.h>
+
+#include "js/CharacterEncoding.h"  // JS_EncodeStringToUTF8
+#include "js/Exception.h"          // JS::AutoSaveExceptionState
+#include "js/UniquePtr.h"          // JS::UniqueChars
+#include "vm/JSContext.h"          // JSContext
+#include "vm/JSObject.h"           // JSObject
+#include "vm/JSScript.h"           // JSScript
+#include "vm/StringType.h"         // JSString
+#include "vm/SymbolType.h"         // JS::Symbol
+
+using namespace js;
+
+namespace {
+
+enum class AccessLogState : uint8_t { Uninitialized, Disabled, Enabled };
+
+AccessLogState gState = AccessLogState::Uninitialized;
+const char* gScriptFilter = nullptr;
+const char* gObjectFilter = nullptr;
+bool gLogSymbols = false;
+
+thread_local bool gIsLogging = false;
+
+static bool EnvFlagEnabled(const char* value) {
+  return value && value[0] && strcmp(value, "0") != 0 &&
+         strcmp(value, "false") != 0 && strcmp(value, "no") != 0;
+}
+
+static bool Enabled() {
+  if (gState == AccessLogState::Uninitialized) {
+    if (!EnvFlagEnabled(getenv("CAMOUFOX_VM_ACCESS_LOG"))) {
+      gState = AccessLogState::Disabled;
+      return false;
+    }
+
+    gScriptFilter = getenv("CAMOUFOX_VM_ACCESS_FILTER");
+    if (gScriptFilter && !gScriptFilter[0]) {
+      gScriptFilter = nullptr;
+    }
+
+    gObjectFilter = getenv("CAMOUFOX_VM_ACCESS_OBJECT_FILTER");
+    if (gObjectFilter && !gObjectFilter[0]) {
+      gObjectFilter = nullptr;
+    }
+
+    gLogSymbols = EnvFlagEnabled(getenv("CAMOUFOX_VM_ACCESS_SYMBOLS"));
+    gState = AccessLogState::Enabled;
+  }
+
+  return gState == AccessLogState::Enabled;
+}
+
+static const char* CurrentFilename(JSContext* cx, uint32_t* line,
+                                   uint32_t* column) {
+  JSScript* script = cx->currentScript();
+  if (!script) {
+    return nullptr;
+  }
+
+  if (line) {
+    *line = script->lineno();
+  }
+  if (column) {
+    *column = script->column().oneOriginValue();
+  }
+  return script->filename();
+}
+
+static bool ShouldLogForCaller(JSContext* cx, uint32_t* line,
+                               uint32_t* column, const char** filename) {
+  *filename = CurrentFilename(cx, line, column);
+  if (!gScriptFilter) {
+    return true;
+  }
+  return *filename && strstr(*filename, gScriptFilter);
+}
+
+static bool ShouldLogForObject(JSObject* obj, const char** className) {
+  *className = obj && obj->getClass() ? obj->getClass()->name : "<null>";
+  if (!gObjectFilter) {
+    return true;
+  }
+  return *className && strstr(*className, gObjectFilter);
+}
+
+static void FormatId(JSContext* cx, JS::Handle<jsid> id, char* fallback,
+                     size_t fallbackLen, JS::UniqueChars* owned,
+                     const char** out) {
+  *owned = nullptr;
+  *out = fallback;
+
+  if (id.isInt()) {
+    snprintf(fallback, fallbackLen, "%d", id.toInt());
+    return;
+  }
+
+  if (id.isString()) {
+    JS::AutoSaveExceptionState savedExc(cx);
+    *owned = JS_EncodeStringToUTF8(cx, id.toString());
+    if (*owned) {
+      *out = owned->get();
+    } else {
+      snprintf(fallback, fallbackLen, "<string-oom>");
+    }
+    return;
+  }
+
+  if (id.isSymbol()) {
+    snprintf(fallback, fallbackLen, "<symbol>");
+    return;
+  }
+
+  snprintf(fallback, fallbackLen, "<void>");
+}
+
+}  // namespace
+
+void js::MaybeLogCamoufoxVMAccess(JSContext* cx, JS::Handle<JSObject*> obj,
+                                  JS::Handle<jsid> id, const char* op) {
+  if (!Enabled() || gIsLogging) {
+    return;
+  }
+  if (id.isSymbol() && !gLogSymbols) {
+    return;
+  }
+
+  const char* filename = nullptr;
+  const char* className = nullptr;
+  uint32_t line = 0;
+  uint32_t column = 0;
+  if (!ShouldLogForCaller(cx, &line, &column, &filename) ||
+      !ShouldLogForObject(obj, &className)) {
+    return;
+  }
+
+  gIsLogging = true;
+
+  char propFallback[64];
+  const char* prop = nullptr;
+  JS::UniqueChars ownedProp;
+  FormatId(cx, id, propFallback, sizeof(propFallback), &ownedProp, &prop);
+
+  fprintf(stderr,
+          "[camoufox-vm-access] op=%s class=%s prop=%s script=%s:%u:%u\n", op,
+          className ? className : "<null>", prop ? prop : "<null>",
+          filename ? filename : "<unknown>", line, column);
+  fflush(stderr);
+
+  gIsLogging = false;
+}
+
+void js::MaybeLogCamoufoxVMOwnKeys(JSContext* cx, JS::Handle<JSObject*> obj,
+                                   unsigned flags) {
+  if (!Enabled() || gIsLogging) {
+    return;
+  }
+
+  const char* filename = nullptr;
+  const char* className = nullptr;
+  uint32_t line = 0;
+  uint32_t column = 0;
+  if (!ShouldLogForCaller(cx, &line, &column, &filename) ||
+      !ShouldLogForObject(obj, &className)) {
+    return;
+  }
+
+  gIsLogging = true;
+
+  fprintf(stderr,
+          "[camoufox-vm-access] op=ownKeys class=%s flags=0x%x script=%s:%u:%u\n",
+          className ? className : "<null>", flags,
+          filename ? filename : "<unknown>", line, column);
+  fflush(stderr);
+
+  gIsLogging = false;
+}
