+void nsGlobalWindowInner::SetScreenAvailableRect(int32_t aWidth,
+                                                 int32_t aHeight,
+                                                 int32_t aLeft, int32_t aTop,
+                                                 ErrorResult& aRv) {
+  uint32_t userContextId = ScreenDimensionManager::GetUserContextIdFromWindow(this);
+
+  if (aWidth <= 0 || aHeight <= 0 || aLeft < 0 || aTop < 0) {
+    aRv.ThrowTypeError(
+        "Screen available dimensions must be positive and offsets must be non-negative");
+    return;
+  }
+
+  ScreenDimensionManager::SetAvailableRect(userContextId, aWidth, aHeight,
+                                           aLeft, aTop);
+  ScreenDimensionManager::DisableAvailableFunction(userContextId);
+
+  if (JSContext* cx = nsContentUtils::GetCurrentJSContext()) {
+    JS::Rooted<JSObject*> global(cx, JS::CurrentGlobalOrNull(cx));
+    if (global) {
+      JS::Rooted<JS::Value> undef(cx, JS::UndefinedValue());
+      JS_SetProperty(cx, global, "setScreenAvailableRect", undef);
+      JS_DeleteProperty(cx, global, "setScreenAvailableRect");
+    }
+  }
+}
