+/* static */ void
+ScreenDimensionManager::SetAvailableRect(uint32_t aUserContextId,
+                                         int32_t aWidth, int32_t aHeight,
+                                         int32_t aLeft, int32_t aTop) {
+  nsString widthKey, heightKey, leftKey, topKey;
+  widthKey.AppendPrintf("screenAvailWidth_%u", aUserContextId);
+  heightKey.AppendPrintf("screenAvailHeight_%u", aUserContextId);
+  leftKey.AppendPrintf("screenAvailLeft_%u", aUserContextId);
+  topKey.AppendPrintf("screenAvailTop_%u", aUserContextId);
+  RoverfoxStorageManager::PutUint(widthKey, static_cast<uint32_t>(aWidth));
+  RoverfoxStorageManager::PutUint(heightKey, static_cast<uint32_t>(aHeight));
+  RoverfoxStorageManager::PutUint(leftKey, static_cast<uint32_t>(aLeft));
+  RoverfoxStorageManager::PutUint(topKey, static_cast<uint32_t>(aTop));
+}
+
+/* static */ bool
+ScreenDimensionManager::GetAvailableRect(uint32_t aUserContextId,
+                                         int32_t* aWidth, int32_t* aHeight,
+                                         int32_t* aLeft, int32_t* aTop) {
+  nsString widthKey, heightKey, leftKey, topKey;
+  widthKey.AppendPrintf("screenAvailWidth_%u", aUserContextId);
+  heightKey.AppendPrintf("screenAvailHeight_%u", aUserContextId);
+  leftKey.AppendPrintf("screenAvailLeft_%u", aUserContextId);
+  topKey.AppendPrintf("screenAvailTop_%u", aUserContextId);
+
+  uint32_t width = 0, height = 0, left = 0, top = 0;
+  RoverfoxStorageManager::GetUint(widthKey, width);
+  RoverfoxStorageManager::GetUint(heightKey, height);
+  RoverfoxStorageManager::GetUint(leftKey, left);
+  RoverfoxStorageManager::GetUint(topKey, top);
+
+  if (width > 0 && height > 0) {
+    *aWidth = static_cast<int32_t>(width);
+    *aHeight = static_cast<int32_t>(height);
+    *aLeft = static_cast<int32_t>(left);
+    *aTop = static_cast<int32_t>(top);
+    return true;
+  }
+  return false;
+}
