 FILE* gLogFile = nullptr;
@@ -77,6 +78,7 @@ static bool Enabled() {
     }
 
     gLogSymbols = EnvFlagEnabled(getenv("ROTUNDA_VM_ACCESS_SYMBOLS"));
+    gLogReturns = EnvFlagEnabled(getenv("ROTUNDA_VM_ACCESS_RETURNS"));
     gMaxCallArgs =
         EnvUnsigned(getenv("ROTUNDA_VM_ACCESS_MAX_ARGS"), 8, 32);
     gMaxStringBytes =
@@ -414,3 +416,111 @@ void js::MaybeLogRotundaVMOwnKeys(JSContext* cx, JS::Handle<JSObject*> obj,
 }
 
 bool js::IsRotundaVMAccessLogEnabled() { return Enabled(); }
+
+void js::MaybeLogRotundaVMAccessResult(JSContext* cx,
+                                        JS::Handle<JSObject*> obj,
+                                        JS::Handle<jsid> id, const char* op,
+                                        bool ok,
+                                        JS::Handle<JS::Value> value) {
+  if (!Enabled() || !gLogReturns || gIsLogging) {
+    return;
+  }
+  if (id.isSymbol() && !gLogSymbols) {
+    return;
+  }
+
+  const char* filename = nullptr;
+  const char* className = nullptr;
+  uint32_t line = 0;
+  uint32_t column = 0;
+  if (!ShouldLogForCaller(cx, &line, &column, &filename) ||
+      !ShouldLogForObject(obj, &className)) {
+    return;
+  }
+
+  gIsLogging = true;
+
+  char propFallback[64];
+  const char* prop = nullptr;
+  JS::UniqueChars ownedProp;
+  FormatId(cx, id, propFallback, sizeof(propFallback), &ownedProp, &prop);
+
+  FILE* stream = LogStream();
+  fprintf(stream,
+          "[rotunda-vm-access] op=%s-return class=%s prop=%s ok=%s result=",
+          op, className ? className : "<null>", prop ? prop : "<null>",
+          ok ? "true" : "false");
+  if (ok) {
+    PrintValue(cx, value);
+  } else {
+    fputs("<error>", stream);
+  }
+  fprintf(stream, " script=%s:%u:%u\n", filename ? filename : "<unknown>",
+          line, column);
+  fflush(stream);
+
+  gIsLogging = false;
+}
+
+void js::MaybeLogRotundaVMHasResult(JSContext* cx,
+                                     JS::Handle<JSObject*> obj,
+                                     JS::Handle<jsid> id, const char* op,
+                                     bool ok, bool found) {
+  JS::RootedValue value(cx);
+  if (ok) {
+    value.setBoolean(found);
+  }
+  MaybeLogRotundaVMAccessResult(cx, obj, id, op, ok, value);
+}
+
+void js::MaybeLogRotundaVMCallResult(JSContext* cx, const JS::CallArgs& args,
+                                      const char* op, const char* kind,
+                                      bool ok) {
+  if (!Enabled() || !gLogReturns || gIsLogging) {
+    return;
+  }
+
+  const char* filename = nullptr;
+  uint32_t line = 0;
+  uint32_t column = 0;
+  if (!ShouldLogForCaller(cx, &line, &column, &filename)) {
+    return;
+  }
+
+  JSObject* calleeObj =
+      args.calleev().isObject() ? &args.calleev().toObject() : nullptr;
+  JSObject* thisObj =
+      args.thisv().isObject() ? &args.thisv().toObject() : nullptr;
+
+  const char* calleeClass = ObjectClassName(calleeObj);
+  const char* thisClass = thisObj ? ObjectClassName(thisObj) : "<primitive>";
+  JS::UniqueChars ownedFunctionName;
+  const char* functionName = nullptr;
+  FormatFunctionName(cx, calleeObj, &ownedFunctionName, &functionName);
+
+  if (gObjectFilter && !MatchesObjectFilter(calleeClass) &&
+      !MatchesObjectFilter(thisClass) && !MatchesObjectFilter(functionName)) {
+    return;
+  }
+
+  gIsLogging = true;
+
+  FILE* stream = LogStream();
+  fprintf(stream,
+          "[rotunda-vm-access] op=%s-return kind=%s calleeClass=%s callee=%s "
+          "thisClass=%s ok=%s result=",
+          op, kind ? kind : "<unknown>", calleeClass,
+          functionName ? functionName : "<anonymous>", thisClass,
+          ok ? "true" : "false");
+  if (ok) {
+    JS::RootedValue rval(cx, args.rval());
+    PrintValue(cx, rval);
+  } else {
+    fputs("<error>", stream);
+  }
+  fprintf(stream, " script=%s:%u:%u\n", filename ? filename : "<unknown>",
+          line, column);
+  fflush(stream);
+
+  gIsLogging = false;
+}
