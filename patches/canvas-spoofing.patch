+uint32_t CanvasRenderingContext2D::GetCanvasUserContextId() const {
+  if (mCanvasElement) {
+    if (Document* doc = mCanvasElement->GetOwnerDocument()) {
+      if (BrowsingContext* bc = doc->GetBrowsingContext()) {
+        return bc->OriginAttributesRef().mUserContextId;
+      }
+      if (nsPIDOMWindowInner* win = doc->GetInnerWindow()) {
+        if (BrowsingContext* bc = win->GetBrowsingContext()) {
+          return bc->OriginAttributesRef().mUserContextId;
+        }
+      }
+    }
+  }
+
+  if (WorkerPrivate* workerPrivate = GetCurrentThreadWorkerPrivate()) {
+    return workerPrivate->GetOriginAttributes().mUserContextId;
+  }
+
+  return 0;
+}
