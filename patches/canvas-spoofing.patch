+#include "CanvasFingerprintManager.h"
+
+#include "MaskConfig.hpp"
+#include "RoverfoxStorageManager.h"
+#include "mozilla/dom/BrowsingContext.h"
+#include "nsGlobalWindowInner.h"
+#include "xpcpublic.h"
+
+namespace mozilla {
+namespace dom {
+
+/* static */ nsString
+CanvasFingerprintManager::DisabledKeyForUserContext(uint32_t aUserContextId) {
+  nsString key;
+  key.AppendPrintf("canvas_disabled_%u", aUserContextId);
+  return key;
+}
+
+/* static */ void
+CanvasFingerprintManager::DisableFunction(uint32_t aUserContextId) {
+  RoverfoxStorageManager::PutBool(DisabledKeyForUserContext(aUserContextId),
+                                  true);
+}
+
+/* static */ void CanvasFingerprintManager::SetSeed(uint32_t aUserContextId,
+                                                     uint32_t aSeed) {
+  nsString key;
+  key.AppendPrintf("canvasFingerprintSeed_%u", aUserContextId);
+  RoverfoxStorageManager::PutUint(key, aSeed);
+  DisableFunction(aUserContextId);
+}
+
+/* static */ uint32_t
+CanvasFingerprintManager::GetSeed(uint32_t aUserContextId) {
+  nsString key;
+  key.AppendPrintf("canvasFingerprintSeed_%u", aUserContextId);
+
+  uint32_t seed = 0;
+  if (RoverfoxStorageManager::GetUint(key, seed) && seed != 0) {
+    return seed;
+  }
+
+  // Fallback to the launch profile for workers and off-main-thread paths that
+  // cannot see the window-scoped WebIDL bridge.
+  if (auto canvas = MaskConfig::Profile().getCanvas()) {
+    if (auto profileSeed = canvas->getSeed()) {
+      if (*profileSeed > 0) {
+        return static_cast<uint32_t>(*profileSeed);
+      }
+    }
+  }
+
+  return 0;
+}
+
+/* static */ uint32_t CanvasFingerprintManager::Mix(uint32_t aSeed,
+                                                     uint32_t aX, uint32_t aY,
+                                                     uint32_t aChannel) {
+  uint32_t value = aSeed ^ 0x9e3779b9u;
+  value ^= aX * 0x85ebca6bu;
+  value ^= aY * 0xc2b2ae35u;
+  value ^= aChannel * 0x27d4eb2fu;
+  value ^= value >> 16;
+  value *= 0x7feb352du;
+  value ^= value >> 15;
+  value *= 0x846ca68bu;
+  value ^= value >> 16;
+  return value;
+}
+
+/* static */ void CanvasFingerprintManager::ApplyNoiseToCanvasBytes(
+    uint8_t* aData, uint32_t aWidth, uint32_t aHeight, uint32_t aStride,
+    uint32_t aSeed) {
+  if (!aData || aSeed == 0 || aWidth == 0 || aHeight == 0 ||
+      aStride < aWidth * 4) {
+    return;
+  }
+
+  for (uint32_t y = 0; y < aHeight; ++y) {
+    uint8_t* row = aData + static_cast<size_t>(y) * aStride;
+    for (uint32_t x = 0; x < aWidth; ++x) {
+      uint8_t* pixel = row + static_cast<size_t>(x) * 4;
+
+      // Both RGBA and little-endian BGRA readout buffers keep alpha in byte 3.
+      // Preserve transparent pixels and never touch alpha.
+      if (pixel[3] == 0) {
+        continue;
+      }
+
+      for (uint32_t channel = 0; channel < 3; ++channel) {
+        uint8_t value = pixel[channel];
+        // Leave hard bounds alone so transparent/blank/solid clipping behavior
+        // remains as close as possible to the underlying renderer.
+        if (value == 0 || value == 255) {
+          continue;
+        }
+
+        int32_t adjustment =
+            static_cast<int32_t>(Mix(aSeed, x, y, channel) % 3) - 1;
+        if (adjustment < 0) {
+          pixel[channel] = value - 1;
+        } else if (adjustment > 0) {
+          pixel[channel] = value + 1;
+        }
+      }
+    }
+  }
+}
+
+/* static */ bool
+CanvasFingerprintManager::IsFunctionEnabledForWebIDL(JSContext* aCx,
+                                                      JSObject* aObj) {
+  nsGlobalWindowInner* win = xpc::WindowOrNull(aObj);
+  if (!win) {
+    return false;
+  }
+
+  uint32_t userContextId = 0;
+  if (BrowsingContext* bc = win->GetBrowsingContext()) {
+    userContextId = bc->OriginAttributesRef().mUserContextId;
+  }
+
+  bool disabled = false;
+  RoverfoxStorageManager::GetBool(DisabledKeyForUserContext(userContextId),
+                                  disabled);
+  return !disabled;
+}
+
+}  // namespace dom
+}  // namespace mozilla
